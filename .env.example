# Supabase (optional — app falls back to local JSON storage when unset)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SITE_URL=

# Session signing secret (REQUIRED in production).
# Used to sign HttpOnly session cookies (HMAC-SHA256) — see lib/auth.ts.
# Generate a strong random value, e.g.:  openssl rand -hex 32
# If unset or too short, production authentication fails closed. A known
# development-only fallback is used only outside production.
APP_SECRET=

# Optional — Zoneomics zoning API key. When unset, the app uses the built-in
# municipal fallback database (lib/zoningLookup.ts).
ZONEOMICS_API_KEY=

# Optional — Stripe billing (lib/stripe.ts). When unset, /api/billing/* and
# /api/webhooks/stripe return 503 "Billing is not configured."
# STRIPE_SECRET_KEY: from the Stripe dashboard (use a test-mode key in dev).
# STRIPE_PRICE_ID: legacy single-plan recurring Price id (kept for back-compat).
# STRIPE_WEBHOOK_SECRET: from the webhook endpoint's settings in Stripe —
#   required to verify that webhook requests genuinely came from Stripe.
STRIPE_SECRET_KEY=
STRIPE_PRICE_ID=
STRIPE_WEBHOOK_SECRET=

# Optional — plan-based billing (lib/billingPlans.ts, docs/pricing-strategy.md).
# Each plan needs a flat recurring base Price and a metered overage Price
# (Stripe dashboard: Product > add a metered price, usage_type=metered).
# Leave unset and a plan stays "not yet configured" until you add it here.
STRIPE_PRICE_STARTER_BASE=
STRIPE_PRICE_STARTER_METERED=
STRIPE_PRICE_GROWTH_BASE=
STRIPE_PRICE_GROWTH_METERED=

# Optional — Stripe Billing Meter event name for qualified-proposal usage
# (lib/stripe.ts reportQualifiedProposalUsage). Must match the Meter's
# event_name configured in the Stripe dashboard. Defaults to "qualified_proposal".
STRIPE_METER_EVENT_NAME=

# Optional — transactional email (lib/email.ts), used by the password-reset
# flow (/api/auth/forgot-password, /api/auth/reset-password) and lead
# notification emails. When unset, those emails are silently skipped — the
# password-reset *links* still work, builders just won't receive them, so set
# this before relying on password reset in production.
# RESEND_API_KEY: from https://resend.com dashboard.
# EMAIL_FROM: must be a verified sender/domain in Resend. Defaults to
#   Resend's shared onboarding@resend.dev sender if unset (fine for testing,
#   not for production — verify your own domain).
RESEND_API_KEY=
EMAIL_FROM=

# Optional — shared rate-limit store (lib/rateLimit.ts). When unset, rate
# limits (login, register, password reset, lead submission, zoning lookups)
# fall back to an in-memory counter that is process-local. On serverless
# (Vercel) that means every concurrent instance gets its own counter, so the
# effective limit is much higher than it looks in code. Set these in
# production to make the limits real.
# UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN: from the Upstash
# console (https://upstash.com) — create a Redis database, REST API tab.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Production persistence is fail-closed: when Supabase is unavailable, ADUflow
# will not write business records to ephemeral Vercel storage. Local JSON
# fallback remains available only for local development and tests.
